# -------------------------------                                                        # why: visual separator for the next section
# STEP 0: Helpers (sanitization + safe prompts)                                          # why: keeps the main flow readable

function Get-RgToken {                                                                 # why: consistent, reusable sanitizer for RG token
    param([string]$RgName)                                                             # why: accept a raw RG name from Azure
    $token = $RgName.ToLowerInvariant()                                                # why: normalize case so names are consistent
    $token = ($token -replace '[^a-z0-9-]', '-')                                       # why: replace invalid name chars with dash to avoid deployment failures
    $token = ($token -replace '-{2,}', '-')                                            # why: collapse repeated dashes for readability
    $token = $token.Trim('-')                                                          # why: remove leading/trailing dashes to keep names clean
    if ([string]::IsNullOrWhiteSpace($token)) { $token = "rg" }                         # why: guarantee a non-empty token even for odd RG names
    return $token                                                                      # why: return the safe token for naming created resources
}                                                                                      # why: end helper function

function Read-Choice {                                                                 # why: consistent prompting with default
    param(                                                                             # why: define inputs
        [string]$Prompt,                                                              # why: message shown to user
        [string[]]$Valid,                                                             # why: allowed answers
        [string]$Default                                                              # why: default answer if user presses Enter
    )                                                                                 # why: end param block
    while ($true) {                                                                    # why: loop until a valid answer comes back
        $raw = Read-Host "$Prompt (default: $Default)"                                 # why: ask user for input but show default
        if ([string]::IsNullOrWhiteSpace($raw)) { $raw = $Default }                    # why: apply default when user hits Enter
        if ($Valid -contains $raw) { return $raw }                                     # why: return only valid answers
        Write-Host "Invalid choice. Valid: $($Valid -join ', ')" -ForegroundColor Yellow # why: guide the user without failing abruptly
    }                                                                                  # why: end loop
}                                                                                      # why: end helper function

# -------------------------------                                                        # why: visual separator for module check
# STEP 0B: Ensure needed Az cmdlets exist                                                # why: DCR creation/association cmdlets are Az.Monitor [9](https://learn.microsoft.com/en-us/powershell/module/az.monitor/new-azdatacollectionrule?view=azps-15.4.0)[10](https://learn.microsoft.com/en-us/powershell/module/az.monitor/new-azdatacollectionruleassociation?view=azps-15.4.0)

if (-not (Get-Command New-AzDataCollectionRule -ErrorAction SilentlyContinue)) {       # why: verify DCR cmdlet exists before proceeding [9](https://learn.microsoft.com/en-us/powershell/module/az.monitor/new-azdatacollectionrule?view=azps-15.4.0)
    throw "Missing cmdlet New-AzDataCollectionRule. Ensure Az.Monitor is installed/loaded." # why: stop early with actionable error
