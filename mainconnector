    throw "Missing cmdlet New-AzDataCollectionRuleAssociation. Ensure Az.Monitor is installed/loaded." # why: stop early with actionable error
}                                                                                      # why: end check

# -------------------------------                                                        # why: visual separator for context
# STEP 1: Pick the Resource Group to work with                                           # why: user asked to list RGs and pick by number

$context = Get-AzContext                                                                # why: confirm we’re authenticated and have a subscription context
if (-not $context) { throw "No AzContext found. Run Connect-AzAccount first." }         # why: fail with clear guidance if not logged in

$subscriptionId = $context.Subscription.Id                                              # why: store subscription id for logging/reporting
Write-Host "Using subscription: $($context.Subscription.Name) ($subscriptionId)" -ForegroundColor Cyan # why: show user which subscription is targeted

$resourceGroups = Get-AzResourceGroup | Sort-Object ResourceGroupName                   # why: list available RGs for user selection
if (-not $resourceGroups -or $resourceGroups.Count -eq 0) { throw "No resource groups found in this subscription." } # why: guard against empty subscriptions

Write-Host "Available Resource Groups:" -ForegroundColor Cyan                           # why: prompt user to choose a target RG
for ($i = 0; $i -lt $resourceGroups.Count; $i++) {                                      # why: number the RG list for easy selection
    Write-Host ("  [{0}] {1} ({2})" -f ($i+1), $resourceGroups[$i].ResourceGroupName, $resourceGroups[$i].Location) -ForegroundColor Gray # why: show RG + region
}                                                                                       # why: end RG list loop

$rgIndexRaw = Read-Host "Enter the number of the resource group you want to work with"  # why: let user choose RG by index
if ($rgIndexRaw -notmatch '^\d+$') { throw "Selection must be a number. Re-run and choose a valid RG index." } # why: validate numeric input
$rgIndex = [int]$rgIndexRaw                                                             # why: convert to integer for indexing
if ($rgIndex -lt 1 -or $rgIndex -gt $resourceGroups.Count) { throw "Selection out of range. Re-run and choose a valid RG index." } # why: validate bounds

$rgName = $resourceGroups[$rgIndex-1].ResourceGroupName                                 # why: chosen RG display name
$rgLocation = $resourceGroups[$rgIndex-1].Location                                      # why: chosen RG location (region)
$rgToken = Get-RgToken -RgName $rgName                                                   # why: sanitized token for naming resources (user approved sanitization)
$dateToken = (Get-Date -Format "MMddyyyy")                                               # why: MMDDYYYY suffix per your standard
Write-Host "Selected RG: $rgName | Location: $rgLocation | Token: $rgToken | Date: $dateToken" -ForegroundColor Green # why: confirm selection + derived naming

# -------------------------------                                                        # why: visual separator for workspace detection
# STEP 2: Detect “monitoring tooling” and recommend a workspace                          # why: user wanted awareness of Sentinel/Insights/Policy/Defender and workspace reuse

$allWorkspaces = Get-AzOperationalInsightsWorkspace                                      # why: enumerate workspaces to allow “use existing” selection
$workspacesInRg = @()                                                                    # why: list workspaces in selected RG first (UX requirement)
$workspacesOutRg = @()                                                                   # why: list workspaces outside selected RG second (UX requirement)

foreach ($ws in $allWorkspaces) {                                                       # why: split into in-RG vs out-of-RG
    if ($ws.ResourceGroupName -eq $rgName) { $workspacesInRg += $ws }                    # why: capture those in the chosen RG first
    else { $workspacesOutRg += $ws }                                                     # why: capture those outside chosen RG for transparency
}                                                                                       # why: end workspace split loop

# --- Detect Sentinel / VMInsights solutions via OMS “solutions” resources              # why: quick heuristic to find workspaces tied to common monitoring tools
$solutions = Get-AzResource -ResourceType "Microsoft.OperationsManagement/solutions" -ErrorAction SilentlyContinue # why: solutions often indicate Sentinel/VMInsights workspace usage
$sentinelWorkspaceIds = @()                                                              # why: collect workspace ids linked to Sentinel
$vminsightsWorkspaceIds = @()                                                            # why: collect workspace ids linked to VMInsights

foreach ($sol in ($solutions | Where-Object { $_.Properties -ne $null })) {              # why: only process solutions that have properties payload
    $solutionType = $sol.Properties.solutionType                                         # why: solutionType identifies the solution installed
    $wsId = $sol.Properties.workspaceResourceId                                          # why: workspaceResourceId links solution to a workspace
    if ($solutionType -eq "SecurityInsights" -and $wsId) { $sentinelWorkspaceIds += $wsId } # why: Sentinel solution type is SecurityInsights (workspace-level)
    if ($solutionType -eq "VMInsights" -and $wsId) { $vminsightsWorkspaceIds += $wsId }  # why: VMInsights solution type is VMInsights (workspace-level)
}                                                                                       # why: end solutions loop

$sentinelWorkspaceIds = $sentinelWorkspaceIds | Select-Object -Unique                    # why: dedupe ids for clean messaging
$vminsightsWorkspaceIds = $vminsightsWorkspaceIds | Select-Object -Unique                # why: dedupe ids for clean messaging

$policyAssignments = Get-AzPolicyAssignment -ErrorAction SilentlyContinue                # why: detect whether Azure Policy is actively used in the subscription (high-level)
$policyPresent = ($policyAssignments -and $policyAssignments.Count -gt 0)                # why: boolean used to inform the user

$toolingDetected = @()                                                                   # why: store human-readable detected tooling hints
if ($sentinelWorkspaceIds.Count -gt 0) { $toolingDetected += "Sentinel (SecurityInsights)" } # why: report Sentinel detection
if ($vminsightsWorkspaceIds.Count -gt 0) { $toolingDetected += "VM Insights (VMInsights)" }   # why: report VM Insights detection
if ($policyPresent) { $toolingDetected += "Azure Policy (assignments present)" }         # why: report policy usage (not workspace-specific)

if ($toolingDetected.Count -gt 0) {                                                     # why: only show detection banner if we found something
    Write-Host ("Detected monitoring/security signals: {0}" -f ($toolingDetected -join ", ")) -ForegroundColor Cyan # why: inform user early
} else {                                                                                # why: provide explicit confirmation of “no signals found”
    Write-Host "No Sentinel/VMInsights solution linkage detected (Policy may still exist). Continuing..." -ForegroundColor DarkCyan # why: avoid surprise later
}                                                                                       # why: end detection message

# --- Choose default “recommended workspace” (prefer Sentinel, else VMInsights)         # why: align with your plan: offer to use the workspace used by tooling
$recommendedWorkspaceId = $null                                                          # why: store one recommended workspace id if available
if ($sentinelWorkspaceIds.Count -gt 0) { $recommendedWorkspaceId = $sentinelWorkspaceIds[0] } # why: Sentinel is the strongest “security monitoring” signal
elseif ($vminsightsWorkspaceIds.Count -gt 0) { $recommendedWorkspaceId = $vminsightsWorkspaceIds[0] } # why: fall back to VM Insights linkage if no Sentinel

$recommendedWorkspace = $null                                                            # why: hold resolved workspace object for convenience
if ($recommendedWorkspaceId) {                                                           # why: resolve workspace object only if we have an id
    $recommendedWorkspace = $allWorkspaces | Where-Object { $_.ResourceId -eq $recommendedWorkspaceId } | Select-Object -First 1 # why: find matching workspace by resourceId
}                                                                                       # why: end resolve block

# -------------------------------                                                        # why: visual separator for workspace selection UX
# STEP 2B: Ask: use tooling-linked workspace or use different workspace for SOC2        # why: implements your STEP 2 option text requirement

$workspaceChoice = $null                                                                 # why: store user’s high-level choice
if ($recommendedWorkspace) {                                                             # why: only offer tooling-linked “quick pick” if we found one
    Write-Host "A workspace linked to existing tooling was found:" -ForegroundColor Cyan # why: explain why we’re recommending it
    Write-Host ("  {0} (RG: {1}, Location: {2})" -f $recommendedWorkspace.Name, $recommendedWorkspace.ResourceGroupName, $recommendedWorkspace.Location) -ForegroundColor Gray # why: show details
    $workspaceChoice = Read-Choice -Prompt "Choose: [1] Use this workspace for SOC2 monitoring, [2] Use a different workspace for SOC2 monitoring" -Valid @("1","2") -Default "1" # why: default to existing to reduce friction
} else {                                                                                 # why: if no recommendation exists, default to “different”
    Write-Host "No tooling-linked workspace identified; you can use an existing workspace or create a new one." -ForegroundColor Cyan # why: set expectation
    $workspaceChoice = "2"                                                               # why: proceed to general selection workflow
}                                                                                       # why: end workspace-choice logic

# -------------------------------                                                        # why: visual separator for workspace list/create
# STEP 2C: Choose existing workspace or create LogAW-soc2-<rg>-MMDDYYYY                  # why: implements Option A naming (no custom names)

$workspace = $null                                                                       # why: will hold the selected/created workspace object

if ($workspaceChoice -eq "1") {                                                         # why: user chose the tooling-linked workspace
    $workspace = $recommendedWorkspace                                                   # why: assign recommended workspace as SOC2 workspace
} else {                                                                                 # why: user chose a different workspace for SOC2
    Write-Host "Workspaces in the selected RG (shown first):" -ForegroundColor Cyan      # why: UX requirement to list current RG first
    if ($workspacesInRg.Count -eq 0) { Write-Host "  (none in this RG)" -ForegroundColor DarkGray } # why: make empty list explicit
    for ($i = 0; $i -lt $workspacesInRg.Count; $i++) {                                   # why: number the in-RG workspaces
        Write-Host ("  [RG {0}] {1}" -f ($i+1), $workspacesInRg[$i].Name) -ForegroundColor Gray # why: show inside-RG workspaces first
    }                                                                                   # why: end in-RG listing

    Write-Host "Workspaces outside the selected RG:" -ForegroundColor Cyan               # why: UX requirement to show out-of-RG and clarify
    if ($workspacesOutRg.Count -eq 0) { Write-Host "  (none outside this RG)" -ForegroundColor DarkGray } # why: make empty list explicit
    for ($j = 0; $j -lt $workspacesOutRg.Count; $j++) {                                   # why: number the out-of-RG workspaces
        Write-Host ("  [OUT {0}] {1} (RG: {2})" -f ($j+1), $workspacesOutRg[$j].Name, $workspacesOutRg[$j].ResourceGroupName) -ForegroundColor DarkGray # why: highlight “outside RG”
    }                                                                                   # why: end out-of-RG listing

    $useExistingOrCreate = Read-Choice -Prompt "Choose: [1] Use an existing workspace, [2] Create a new SOC2 workspace" -Valid @("1","2") -Default "2" # why: present clear choice
    if ($useExistingOrCreate -eq "1") {                                                  # why: user wants existing
        $existingWsName = Read-Host "Enter the EXACT name of the workspace to use"       # why: simplest UX without fragile index mapping across two lists
        $workspace = $allWorkspaces | Where-Object { $_.Name -eq $existingWsName } | Select-Object -First 1 # why: resolve workspace by name
        if (-not $workspace) { throw "Workspace not found by name: $existingWsName" }   # why: fail clearly if name mismatch
    } else {                                                                             # why: user wants to create a new SOC2 workspace
        $workspaceName = "LogAW-soc2-$rgToken-$dateToken"                                # why: enforce Option A naming with LogAW prefix and -soc2- segment
        Write-Host "Creating Log Analytics Workspace: $workspaceName" -ForegroundColor Cyan # why: show what will be created
        $workspace = New-AzOperationalInsightsWorkspace -ResourceGroupName $rgName -Name $workspaceName -Location $rgLocation -Sku PerGB2018 # why: create workspace in chosen RG/region
    }                                                                                   # why: end create vs existing
}                                                                                       # why: end workspace selection

$workspaceId = $workspace.ResourceId                                                     # why: resourceId is required for diagnostic settings and DCR destinations
$workspaceLocation = $workspace.Location                                                 # why: DCRs must be created in same region as workspace for metrics export [3](https://learn.microsoft.com/en-us/azure/azure-monitor/data-collection/metrics-export-create)[11](https://learn.microsoft.com/en-us/azure/azure-monitor/data-collection/data-collection-rule-create-edit)
Write-Host ("SOC2 Workspace: {0} | RG: {1} | Location: {2}" -f $workspace.Name, $workspace.ResourceGroupName, $workspaceLocation) -ForegroundColor Green # why: confirm final selection

# -------------------------------                                                        # why: visual separator for scanning resources
# STEP 3: Scan resources (subscription-wide inventory + focus on chosen RG)             # why: you wanted initial scan; changes apply per selected RG

$allResources = Get-AzResource                                                           # why: subscription-wide scan for reporting and awareness
$rgResources = $allResources | Where-Object { $_.ResourceGroupName -eq $rgName }         # why: only apply SOC2 settings to resources in the chosen RG

Write-Host ("Total resources in subscription: {0}" -f $allResources.Count) -ForegroundColor Cyan # why: show scale of scan
Write-Host ("Resources in selected RG '{0}': {1}" -f $rgName, $rgResources.Count) -ForegroundColor Cyan # why: show scope of changes

$diagSettingName = "diag-logs-soc2-$rgToken-$dateToken"                                   # why: enforce naming convention for diagnostic setting name

$scanResults = @()                                                                       # why: collect scan rows for CSV output
foreach ($res in $rgResources) {                                                         # why: evaluate each resource in selected RG
    $supported = $false                                                                  # why: will flip true if diagnostic categories exist
    $existingDiag = @()                                                                  # why: store existing diagnostic setting objects if any
    $existingDestinations = @()                                                          # why: store human-readable destination summary strings
    $existingDiagNames = @()                                                             # why: store existing diagnostic setting names

    try {                                                                                # why: category discovery is the safest support test for diag settings
        $cats = Get-AzDiagnosticSettingCategory -ResourceId $res.ResourceId               # why: if this succeeds and returns categories, resource supports diag settings
        if ($cats -and $cats.Count -gt 0) { $supported = $true }                         # why: ensure at least one category exists
    } catch {                                                                            # why: resources without support often throw exceptions here
        $supported = $false                                                               # why: keep false when not supported
        $cats = @()                                                                       # why: avoid null usage later
    }                                                                                    # why: end support test

    if ($supported) {                                                                    # why: only query settings if support exists
        try {                                                                            # why: existing settings must be detected for “keep vs add” prompts
            $existingDiag = Get-AzDiagnosticSetting -ResourceId $res.ResourceId           # why: fetch diagnostic settings currently applied
        } catch {                                                                        # why: treat failures as “no settings”
            $existingDiag = @()                                                           # why: avoid null branching later
        }                                                                                # why: end existing diag fetch
    }                                                                                    # why: end “supported” guard

    foreach ($ds in $existingDiag) {                                                     # why: summarize any existing routes for the user’s decision
        $existingDiagNames += $ds.Name                                                   # why: collect diag setting names
        if ($ds.WorkspaceId) { $existingDestinations += ("Workspace:{0}" -f $ds.WorkspaceId) } # why: show workspace route if present
        if ($ds.StorageAccountId) { $existingDestinations += ("Storage:{0}" -f $ds.StorageAccountId) } # why: show storage route if present
        if ($ds.EventHubAuthorizationRuleId) { $existingDestinations += ("EventHubAuth:{0}" -f $ds.EventHubAuthorizationRuleId) } # why: show event hub route if present
    }                                                                                    # why: end destination summary loop

    $scanResults += [PSCustomObject]@{                                                   # why: build a clean row per resource for reporting
        ResourceName             = $res.Name                                             # why: identifyly
        ResourceType             = $res.ResourceType                                     # why: group analysis by type
        ResourceId               = $res.ResourceId                                       # why: needed for follow-up calls and traceability
        AzureMonitorSupported    = $supported                                            # why: indicates whether we can apply diagnostic settings
        ExistingDiagSettingNames = ($existingDiagNames -join ";")                        # why: show existing settings to support decision prompts
        ExistingDestinations     = ($existingDestinations -join ";")                     # why: show current routing destinations
    }                                                                                    # why: end row build
}                                                                                        # why: end scan loop

Write-Host "Scan complete for selected RG." -ForegroundColor Green                        # why: confirm scan end

# -------------------------------                                                        # why: visual separator for diag settings application
# STEP 4: Apply platform LOGS diagnostic settings (per resource)                         # why: platform resource logs are still collected via diagnostic settings [1](https://www.security-docs.com/blog/soc2-logging-monitoring)[2](https://truvo.ca/blog/security-logging-and-monitoring-architecture-guide)

$alreadyConfigured = $scanResults | Where-Object { $_.AzureMonitorSupported -eq $true -and $_.ExistingDiagSettingNames } # why: find resources already routing somewhere
$notConfigured = $scanResults | Where-Object { $_.AzureMonitorSupported -eq $true -and -not $_.ExistingDiagSettingNames } # why: find resources with no diag settings yet

Write-Host ("Resources with existing diagnostic settings: {0}" -f $alreadyConfigured.Count) -ForegroundColor Cyan # why: show how many need a “keep vs add” decision
Write-Host ("Resources with NO diagnostic settings (eligible for new SOC2 setting): {0}" -f $notConfigured.Count) -ForegroundColor Cyan # why: show eligible count

$applyToExistingMode = "keep"                                                            # why: default to keep existing (per your decision)
if ($alreadyConfigured.Count -gt 0) {                                                    # why: only ask if there are any existing diag settings
    Write-Host "Existing routing detected (showing current destinations):" -ForegroundColor Cyan # why: provide transparency before asking
    foreach ($r in $alreadyConfigured) {                                                  # why: show the user what’s already configured
        Write-Host ("  - {0} | {1}" -f $r.ResourceName, $r.ExistingDestinations) -ForegroundColor Gray # why: compact routing summary
    }                                                                                    # why: end display loop

    $applyToExistingMode = Read-Choice -Prompt "For resources already routing logs, choose: [keep] keep existing only, [add] add SOC2 routing too (no overwrite), [switch] switch to SOC2 (not recommended)" -Valid @("keep","add","switch") -Default "keep" # why: implement your “ask the user” requirement
}                                                                                        # why: end existing prompt decision

# --- Function to create a SOC2 diagnostic setting on a resource                         # why: keeps main loop readable
function Ensure-Soc2DiagSetting {                                                        # why: encapsulate “create diag setting” logic
    param(                                                                               # why: define explicit inputs
        [string]$TargetResourceId,                                                       # why: resource to configure
        [string]$TargetResourceName,                                                     # why: for logging
        [string]$TargetResourceType                                                      # why: for exclusions/logic
    )                                                                                    # why: end param block
    try {                                                                                # why: diagnostic categories vary by resource
        $categories = Get-AzDiagnosticSettingCategory -ResourceId $TargetResourceId       # why: discover available log/metric categories for this resource
    } catch {                                                                            # why: if categories aren’t readable, we can’t configure
        Write-Host ("  [SKIP] Categories not readable: {0}" -f $TargetResourceName) -ForegroundColor Yellow # why: explain skip without crashing
        return                                                                           # why: exit function early
    }                                                                                    # why: end category fetch

    $logCats = $categories | Where-Object { $_.CategoryType -eq "Logs" }                  # why: build enabled settings for log categories
    $metricCats = $categories | Where-Object { $_.CategoryType -eq "Metrics" }            # why: build enabled settings for metric categories (platform logs step can include metrics, but we later prefer DCR metrics export)
    $logSettings = @()                                                                   # why: collect log settings objects
    foreach ($c in $logCats) {                                                           # why: enable all log categories to avoid missing SOC2-relevant sources
        $logSettings += New-AzDiagnosticSettingLogSettingsObject -Category $c.Name -Enabled $true -RetentionPolicyDay 0 -RetentionPolicyEnabled $false # why: enable log category with no retention at diag-setting layer
    }                                                                                    # why: end log categories loop

    $metricSettings = @()                                                                # why: collect metric settings objects
    foreach ($c in $metricCats) {                                                        # why: enable all metric categories *only for this setting object construction* (may be omitted later when using DCR metrics export)
        $metricSettings += New-AzDiagnosticSettingMetricSettingsObject -Category $c.Name -Enabled $true -RetentionPolicyDay 0 -RetentionPolicyEnabled $false # why: enable metric category with no retention at diag-setting layer
    }                                                                                    # why: end metric categories loop

    $params = @{                                                                         # why: use splatting for readable cmd invocation
        Name        = $diagSettingName                                                   # why: enforce standard naming convention
        ResourceId  = $TargetResourceId                                                  # why: target resource id for the diagnostic setting
        WorkspaceId = $workspaceId                                                       # why: SOC2 workspace destination
    }                                                                                    # why: end params
    if ($logSettings.Count -gt 0) { $params["Log"] = $logSettings }                      # why: only include Log parameter if logs exist
    if ($metricSettings.Count -gt 0) { $params["Metric"] = $metricSettings }             # why: only include Metric parameter if metrics exist

    try {                                                                                # why: attempt creation/update of diagnostic setting
        New-AzDiagnosticSetting @params | Out-Null                                       # why: create SOC2 diagnostic setting for this resource
        Write-Host ("  [OK] Created/Updated diag setting on: {0}" -f $TargetResourceName) -ForegroundColor Green # why: success indicator
    } catch {                                                                            # why: handle common failures (RBAC/policy/limits)
        Write-Host ("  [FAILED] {0}: {1}" -f $TargetResourceName, $_.Exception.Message) -ForegroundColor Red # why: show reason but continue
    }                                                                                    # why: end try/catch
}                                                                                        # why: end function

# --- Apply to resources with no existing diag settings (safe default)                   # why: no risk of overwriting
foreach ($r in $notConfigured) {                                                         # why: apply SOC2 diag setting to those missing it
    $resObj = $rgResources | Where-Object { $_.ResourceId -eq $r.ResourceId } | Select-Object -First 1 # why: recover resource object for name/type
    if (-not $resObj) { continue }                                                       # why: safety guard if resource object can’t be found
    Write-Host ("Processing (no existing diag): {0}" -f $resObj.Name) -ForegroundColor Yellow # why: show progress to user
    Ensure-Soc2DiagSetting -TargetResourceId $resObj.ResourceId -TargetResourceName $resObj.Name -TargetResourceType $resObj.ResourceType # why: create SOC2 diagnostic setting
}                                                                                        # why: end no-existing loop

# --- Apply to resources with existing diag settings based on user choice                # why: honors “keep vs add vs switch” policy
