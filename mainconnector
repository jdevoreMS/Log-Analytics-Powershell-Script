        Write-Host ("Switch requested: {0}" -f $resObj.Name) -ForegroundColor Yellow     # why: show risk action
        Write-Host "  NOTE: Switch mode is intentionally not implemented automatically to avoid destructive changes." -ForegroundColor Yellow # why: safety guardrail
