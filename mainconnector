                }                                                                        # why: end log parse
                foreach ($m in $our.Metrics) {                                           # why: parse metric category enabled flags
                    if ($m.Enabled) { $soc2EnabledMetricCats += $m.Category } else { $soc2DisabledMetricCats += $m.Category } # why: classify enabled vs disabled
                }                                                                        # why: end metric parse
            }                                                                            # why: end our-setting exists
        } catch {                                                                        # why: tolerate read failures
            $soc2DiagExists = $false                                                     # why: treat as not verified
        }                                                                                # why: end try/catch
    }                                                                                    # why: end supported guard

    $finalRows += [PSCustomObject]@{                                                     # why: create final CSV record
        ResourceName                = $r.ResourceName                                    # why: identify resource
        ResourceType                = $r.ResourceType                                    # why: identify type
        ResourceId                  = $r.ResourceId                                      # why: traceable key
        AzureMonitorSupported       = $r.AzureMonitorSupported                           # why: whether resource supports diag settings
        ExistingDiagSettingNames    = $r.ExistingDiagSettingNames                         # why: what existed before we ran
        ExistingDestinations        = $r.ExistingDestinations                             # why: where it was routing before
        Soc2DiagSettingName         = $diagSettingName                                    # why: our standard SOC2 diag setting name
        Soc2DiagSettingPresent      = $soc2DiagExists                                     # why: whether our SOC2 diag setting exists now
        Soc2EnabledLogCategories    = ($soc2EnabledLogCats | Sort-Object -Unique) -join ";" # why: categories we enabled (logs)
        Soc2DisabledLogCategories   = ($soc2DisabledLogCats | Sort-Object -Unique) -join ";" # why: categories disabled (logs)
        Soc2EnabledMetricCategories = ($soc2EnabledMetricCats | Sort-Object -Unique) -join ";" # why: categories we enabled (metrics)
        Soc2DisabledMetricCategories= ($soc2DisabledMetricCats | Sort-Object -Unique) -join ";" # why: categories disabled (metrics)
        MetricsDcrName              = $metricsDcrName                                     # why: per-RG metrics DCR name (if created)
        WindowsGuestDcrName         = $winGuestDcrName                                    # why: per-RG Windows guest DCR name
        LinuxGuestDcrName           = $linGuestDcrName                                    # why: per-RG Linux guest DCR name
        Soc2WorkspaceName           = $workspace.Name                                     # why: final SOC2 workspace chosen/created
        Soc2WorkspaceId             = $workspaceId                                        # why: resource id for cross-checking
    }                                                                                    # why: end row creation
}                                                                                        # why: end final scan loop

$csvFileName = ("soc2-onboarding-{0}-{1}.csv" -f $rgToken, (Get-Date -Format "yyyyMMdd-HHmmss")) # why: unique filename to avoid overwrite
$csvPath = Join-Path -Path $PWD.Path -ChildPath $csvFileName                             # why: dynamic “current working directory” CSV path per your requirement
$finalRows | Export-Csv -Path $csvPath -NoTypeInformation                                # why: persist results for evidence and troubleshooting

Write-Host "=================================================================================" -ForegroundColor Cyan # why: summary section divider
Write-Host "SOC2 Onboarding Summary" -ForegroundColor Cyan                                # why: clear summary title
Write-Host "=================================================================================" -ForegroundColor Cyan # why: divider
Write-Host ("RG: {0}" -f $rgName)                                                        # why: show scope
Write-Host ("SOC2 Workspace: {0}" -f $workspace.Name)                                    # why: show workspace used
Write-Host ("CSV saved to: {0}" -f $csvPath)                                             # why: tell user where output is
Write-Host "Verification tips (Log Analytics -> Logs):" -ForegroundColor Cyan            # why: guide user to validate ingestion
Write-Host "  - Platform metrics: query AzureMetricsV2 (allow up to ~15 minutes initially)" -ForegroundColor Gray # why: metrics export lands here [3](https://learn.microsoft.com/en-us/azure/azure-monitor/data-collection/metrics-export-create)
Write-Host "  - Windows guest logs: query Event table" -ForegroundColor Gray             # why: Windows events stored in Event table [5](https://learn.microsoft.com/en-us/azure/azure-monitor/vm/data-collection-windows-events)[6](https://learn.microsoft.com/en-us/azure/azure-monitor/reference/tables/event)
Write-Host "  - Linux guest logs: query Syslog table" -ForegroundColor Gray              # why: Syslog stored in Syslog table [7](https://learn.microsoft.com/en-us/azure/azure-monitor/data-collection/data-collection-rule-overview)
Write-Host "=================================================================================" -ForegroundColor Cyan # why: divider

# Optional: Cloud Shell convenience download                                               # why: only works in Azure Cloud Shell
if (Get-Command download -ErrorAction SilentlyContinue) { download $csvPath }            # why: trigger browser download if running in Cloud Shell
